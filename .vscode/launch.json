{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "pwa-node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vscode/bin/test",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "cwd": "${workspaceFolder}",
      "outputCapture": "std",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
